    "@type" : "TEMPLATE_OVERLAY",
    "uid" : "573df32e-991e-4d41-9660-9e14ad1b08c2",
    "description" : {
      "@type" : "RESOURCE_DESCRIPTION",
      "originalAuthor" : { },
